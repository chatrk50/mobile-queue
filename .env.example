# ---- Server ----
PORT=3000
# Public base URL where THIS app is reachable (used in QR codes & LIFF redirects)
PUBLIC_BASE_URL=http://localhost:3000

# ---- Cashier / staff ----
# PIN required to open the cashier dashboard actions (call next, etc.)
CASHIER_PIN=1234

# ---- Queue behaviour ----
# Notify the customer when this many groups remain ahead of them.
NOTIFY_THRESHOLD=2

# ---- LINE (leave blank to run fully locally with LINE stubbed) ----
# From LINE Developers console -> your Messaging API channel
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
# From LINE Developers console -> LIFF tab (the LIFF app you point the QR at)
LIFF_ID=
