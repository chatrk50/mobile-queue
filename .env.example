# ============================================================================
#  ขายดี KhaiDee — environment template
#  Copy to .env for local dev, or set these in your host's dashboard (Render).
#  Two modes:
#    • Single-tenant (default, SAAS unset)  → the classic one-shop app (YO-DEE).
#    • SaaS (SAAS=1)                         → multi-tenant platform on the `saas` branch.
#  Anything left blank falls back to a safe default (noted per line).
# ============================================================================

# ---------------------------------------------------------------------------
#  Server
# ---------------------------------------------------------------------------
PORT=3000
# Public URL where THIS app is reachable (QR codes, LIFF redirects, email links,
# custom-domain CNAME target). No trailing slash.
PUBLIC_BASE_URL=http://localhost:3000
# Used in transactional/billing email links. Usually the same as PUBLIC_BASE_URL.
BASE_URL=http://localhost:3000
# Number of reverse-proxy hops in front of the app. SECURITY-CRITICAL: this is how
# the real client IP is derived for every rate limit (signup, PIN lockout, SSE cap).
#   • Render (default infra) = 1   ← leave as 1
#   • Add a CDN in front (e.g. Cloudflare) → set to 2
# Setting this wrong lets clients forge X-Forwarded-For to bypass rate limits.
TRUST_PROXY_HOPS=1

# ---------------------------------------------------------------------------
#  Single-tenant cashier (ignored in SaaS mode — each brand sets its own PIN)
# ---------------------------------------------------------------------------
# PIN to open cashier dashboard actions (call next, etc.). CHANGE FOR PRODUCTION.
CASHIER_PIN=1234
# Owner PIN (manager/owner actions). Falls back to CASHIER_PIN if unset.
OWNER_PIN=

# ---------------------------------------------------------------------------
#  Queue behaviour
# ---------------------------------------------------------------------------
NOTIFY_THRESHOLD=2          # notify customer when this many groups remain ahead
WAIT_PER_GROUP_MIN=         # est. minutes per group shown to customers (optional)

# ===========================================================================
#  SaaS MODE  (set SAAS=1 to enable the multi-tenant platform)
# ===========================================================================
SAAS=                       # 1 = multi-tenant SaaS; blank/0 = single-tenant
# Strong random string — REQUIRED in SaaS mode (the app refuses to boot without
# >=16 chars). Signs owner/admin session cookies. Generate: openssl rand -hex 32
SESSION_SECRET=
# Platform-admin console (/admin) password — long random string. SaaS only.
SAAS_ADMIN_PIN=
# Optional 2FA for /admin: a base32 TOTP secret (pair with an authenticator app).
SAAS_ADMIN_TOTP_SECRET=
# Apex/base host of the platform, e.g. khai-dee.com. Used to build per-brand links
# AND to reserve platform-owned hostnames so no tenant can claim them (routing-hijack
# guard). PUBLIC_BASE_URL/BASE_URL hosts are reserved automatically too.
SAAS_BASE=
# Optional: email that receives a notification on every new brand signup.
PLATFORM_ADMIN_EMAIL=
# Free-plan trial length in days (Pro features) for new brands. Default 60.
TRIAL_DAYS=
# "Founder" promo: first N brands lock a discounted lifetime Pro price. Default 50.
FOUNDER_SLOTS=

# ---- SaaS rate limits (per IP / per tenant; sensible defaults if blank) ----
SIGNUP_MAX=                 # max signups per IP per hour (default 5)
ORDER_RATE=                 # max self-order requests per tenant per minute (default 120)
PROMO_RATE=                 # max LINE promo broadcasts per tenant per hour (default 5)

# ---------------------------------------------------------------------------
#  Durable database (Turso / libSQL) — REQUIRED for SaaS production
#  (Without these, storage is LOCAL node:sqlite and EPHEMERAL on Render free.)
# ---------------------------------------------------------------------------
TURSO_DATABASE_URL=         # libsql://… from turso.tech
TURSO_AUTH_TOKEN=           # auth token for the DB above
QUEUE_DATA_DIR=             # local-mode data dir override (dev/tests only)

# ---------------------------------------------------------------------------
#  Transactional email (welcome, receipts, dunning, password reset, nudges)
#  Without these, emails dry-run to the server log (fine for dev).
# ---------------------------------------------------------------------------
SENDGRID_API_KEY=
EMAIL_FROM=                 # verified sender, e.g. "ขายดี KhaiDee <no-reply@khai-dee.com>"

# ---------------------------------------------------------------------------
#  Self-service billing (Omise) — optional. Blank = manual upgrades via /admin.
#  Use test keys (skey_test_… / pkey_test_…) + a test card before going live.
#  Webhook: point Omise at  PUBLIC_BASE_URL/billing/omise/webhook
# ---------------------------------------------------------------------------
OMISE_SECRET_KEY=
OMISE_PUBLIC_KEY=
OMISE_CURRENCY=thb
# Plan prices in satang (optional — these are the defaults; override to re-price).
OMISE_PRO_AMOUNT=29900       # Pro / month  (฿299)
OMISE_PRO_YEAR=299000        # Pro / year   (฿2,990)
OMISE_BIZ_AMOUNT=79900       # Business / month (฿799)
OMISE_BIZ_YEAR=799000        # Business / year  (฿7,990)
OMISE_FOUNDER_AMOUNT=19900   # Founder Pro / month (฿199, first-N lock-in)
OMISE_FOUNDER_YEAR=199000    # Founder Pro / year  (฿1,990)

# ---------------------------------------------------------------------------
#  Payments to the shop (PromptPay / LINE Pay / slip verification) — optional
# ---------------------------------------------------------------------------
PAY_ONLINE=                 # 1 = enable online pay-before-queue
PROMPTPAY_ID=               # PromptPay number/ID for dynamic QR
PROMPTPAY_STATIC=           # static PromptPay QR image URL (alternative)
SLIPOK_API_KEY=             # SlipOK auto slip verification (optional)
SLIPOK_BRANCH_ID=
LINEPAY_CHANNEL_ID=         # LINE Pay (optional)
LINEPAY_CHANNEL_SECRET=
LINEPAY_ENV=                # sandbox | production

# ---------------------------------------------------------------------------
#  LINE Messaging + LIFF (single-tenant only; in SaaS each brand sets its own
#  channel from ⚙ ตั้งค่า). Leave blank to run locally with LINE stubbed.
# ---------------------------------------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LIFF_ID=
LINE_ADD_FRIEND_URL=
GOOGLE_CLIENT_ID=           # Google Sign-In for owner login (optional)
SUPPORT_LINE_URL=           # support contact link shown in-app (optional)

# ---------------------------------------------------------------------------
#  Seeding / branding (single-tenant white-label boot — optional)
# ---------------------------------------------------------------------------
SEED=                       # "blank" = boot a bare brand (no YO-DEE demo menu)
BRAND_NAME=
BRAND_SHORT=
BRAND_UNIT=
BRAND_THEME=
BRAND_LOGO=
