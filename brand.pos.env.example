# ============================================================================
#  PACKAGE 1 — MOBILE POS ONLY  (no LINE / no customer self-order)
#  Copy to your new brand's Render service "Environment" tab and fill in.
#  Staff ring up orders on a tablet, customers get a queue number + pay at the
#  counter (cash / PromptPay QR). NO LINE app, NO customer ordering screen.
# ============================================================================

# ---- Package + first-run seed ----
PACKAGE=pos          # 'pos' = this package. Hides every customer LINE feature.
SEED=blank           # first boot creates ONE empty store+zone named from BRAND_NAME,
                     # with NO YO-DEE menu. Add your menu in the cashier. Set once;
                     # harmless to leave (no-ops after a store exists).

# ---- Brand (drives name / colour / logo / unit everywhere) ----
BRAND_NAME=ร้านของฉัน          # full name (titles, reports, manifest)
BRAND_SHORT=MyShop              # short name (badges, PWA short_name)
BRAND_THEME=#1e3a5f             # primary colour (hex)
BRAND_LOGO=/assets/logo.png     # drop your logo at public/assets/logo.png
BRAND_UNIT=แก้ว                 # counting unit: แก้ว / ถ้วย / ชิ้น / จาน …

# ---- Server ----
PORT=3000
PUBLIC_BASE_URL=https://YOUR-SERVICE.onrender.com

# ---- Staff PINs ----
CASHIER_PIN=1234     # opens the cashier dashboard
OWNER_PIN=           # optional separate owner PIN (blank = use CASHIER_PIN)
SESSION_SECRET=      # set a long random string for signed staff sessions

# ---- Durable database (Turso) — REQUIRED for a real shop so data survives restarts ----
# Create a DB at turso.tech, then paste its URL + token. Leave blank = ephemeral
# (data wiped on every restart — fine only for a quick demo).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ---- Counter PromptPay (optional — shows a QR at the till; NOT online/LINE) ----
PAY_ONLINE=0         # keep 0 for POS-only; customers pay at the counter
PROMPTPAY_ID=        # shop phone / national id for a dynamic-amount QR (optional)

# ---- Queue tuning ----
NOTIFY_THRESHOLD=2
WAIT_PER_GROUP_MIN=3

#  LINE / LIFF / SlipOK / LINE Pay are intentionally OMITTED — this package
#  does not use them. To add customer LINE ordering, use brand.line.env.example.
