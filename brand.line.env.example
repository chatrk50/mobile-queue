# ============================================================================
#  PACKAGE 2 — LINE CONNECTING  (everything in Package 1, PLUS:)
#  Customer self-order in the LINE app (LIFF), LINE push notifications,
#  loyalty stamps, and online payment. Copy to your brand's Render env + fill.
# ============================================================================

# ---- Package + first-run seed ----
PACKAGE=line         # 'line' = full package (default if omitted)
SEED=blank           # first boot = empty store+zone named from BRAND_NAME, no menu.
                     # (Use SEED=demo to load the YO-DEE sample menu for testing.)

# ---- Brand ----
BRAND_NAME=ร้านของฉัน
BRAND_SHORT=MyShop
BRAND_THEME=#1e3a5f
BRAND_LOGO=/assets/logo.png
BRAND_UNIT=แก้ว

# ---- Server ----
PORT=3000
PUBLIC_BASE_URL=https://YOUR-SERVICE.onrender.com   # LINE webhook + LIFF + QR use this

# ---- Staff ----
CASHIER_PIN=1234
OWNER_PIN=
SESSION_SECRET=

# ---- Durable database (Turso) — REQUIRED ----
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ---- LINE (from LINE Developers console) ----
LINE_CHANNEL_ACCESS_TOKEN=     # Messaging API channel → push notifications
LINE_CHANNEL_SECRET=           # Messaging API channel → webhook signature
LIFF_ID=                       # LINE Login channel → LIFF app (endpoint = PUBLIC_BASE_URL/liff/)
LINE_ADD_FRIEND_URL=           # optional: force add-friend gate (OA add-friend URL)

# ---- Online payment (optional) ----
PAY_ONLINE=1                   # enable the online PromptPay QR + slip flow
PROMPTPAY_ID=                  # shop PromptPay (phone/13-digit) for dynamic QR — best for SlipOK
PROMPTPAY_STATIC=              # or a static merchant QR url (customer types amount)
SLIPOK_API_KEY=                # slipok.com auto slip verification (optional)
SLIPOK_BRANCH_ID=
LINEPAY_CHANNEL_ID=            # LINE Pay MERCHANT account (optional; personal wallet won't work)
LINEPAY_CHANNEL_SECRET=
LINEPAY_ENV=sandbox            # 'sandbox' or 'production'

# ---- Queue tuning ----
NOTIFY_THRESHOLD=2
WAIT_PER_GROUP_MIN=3
